# Variable SERVER-SIDE para el proxy interno de Next.js
# Esta variable NO tiene NEXT_PUBLIC_ porque solo la usa el servidor de Next.js
# El navegador nunca ve esta URL directamente — todo pasa por /api/*

# Desarrollo local:
API_URL=http://localhost:4000

# Producción (Render) — agregar en Vercel → Settings → Environment Variables:
# API_URL=https://tu-backend.onrender.com
